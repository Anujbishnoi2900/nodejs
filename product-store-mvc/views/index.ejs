<!DOCTYPE html>
<html>

<head>
<title>Product Store</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<h1>Product Store</h1>

<div class="container">

<% products.forEach(product => { %>

<div class="card">

<img src="<%= product.image %>" width="150">

<h3><%= product.title %></h3>

<p>$<%= product.price %></p>

<a href="/product/<%= product.id %>">View Product</a>

</div>

<% }) %>

</div>

</body>
</html>